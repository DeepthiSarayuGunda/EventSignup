@model List<EventSignup.Models.Event>

<h2>Event Manager</h2>
<p class="text-muted">Select an event to manage attendees.</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Location</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var evt in Model)
        {
            <tr>
                <td>@evt.Title</td>
                <td>@evt.Date.ToString("yyyy-MM-dd")</td>
                <td>@evt.Location</td>
                <td>
                    <a asp-controller="Events" asp-action="ManageAttendees" asp-route-id="@evt.Id" class="btn btn-info text-white">
                        Manage Attendees
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
