@model EventSignup.Models.Event

<h2 class="text-center">Manage Attendees &ndash; @Model.Title</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<div class="card mt-4 mx-auto" style="max-width: 600px;">
    <div class="card-body">
        <h5 class="card-title">Sign Up for @Model.Title</h5>

        <form asp-controller="Events" asp-action="Signup" method="post">
            <input type="hidden" name="eventId" value="@Model.Id" />

            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <input type="text" class="form-control" id="name" name="name" required />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required />
            </div>

            <button type="submit" class="btn btn-success">Sign Up</button>
            <a asp-controller="Events" asp-action="Index" class="btn btn-dark ms-2">Back to Events</a>
        </form>
    </div>
</div>

<h4 class="text-center mt-5">Current Attendees (@Model.Attendees.Count)</h4>

@if (Model.Attendees.Count == 0)
{
    <p class="text-center text-muted">No attendees registered yet.</p>
}
else
{
    <div class="mx-auto" style="max-width: 600px;">
        @foreach (var attendee in Model.Attendees)
        {
            <div class="border-bottom py-2 ps-3">
                <strong>@attendee.Name</strong> (@attendee.Email)
            </div>
        }
    </div>
}
